{
  "name": "@fleet/spiffe-client",
  "version": "0.1.0-alpha.0",
  "description": "SPIFFE workload identity client for Node services. Fetches and caches JWT-SVIDs from spire-bridge, wraps fetch() with SVID auth, verifies inbound SVIDs.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-workflows/spiffe-client-node.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
